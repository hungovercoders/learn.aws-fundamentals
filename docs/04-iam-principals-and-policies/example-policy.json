{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadObjectsInBreweryDataBucket",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::tinyrebel-brewery-data",
        "arn:aws:s3:::tinyrebel-brewery-data/*"
      ]
    },
    {
      "Sid": "DenyWritesEvenIfAllowedElsewhere",
      "Effect": "Deny",
      "Action": [
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:DeleteBucket"
      ],
      "Resource": [
        "arn:aws:s3:::tinyrebel-brewery-data",
        "arn:aws:s3:::tinyrebel-brewery-data/*"
      ]
    }
  ]
}
